# Frontend environment variables
# Copy to .env.local for local development
REACT_APP_API_URL=http://localhost:8000

# OIDC login (Okta or other provider)
REACT_APP_OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
REACT_APP_OKTA_CLIENT_ID=your_okta_client_id

# Local auth mode — set to true to skip OIDC and use username/password login
# Also set LOCAL_AUTH=true in backend/.env
REACT_APP_LOCAL_AUTH=false
