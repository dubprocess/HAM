# =============================================================
# HAM — Hardware Asset Manager — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# Database
DATABASE_URL=postgresql://assetuser:changeme123@postgres:5432/asset_tracker

# Application
SECRET_KEY=your-random-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# Asset tagging
# Asset tags are generated as <ASSET_TAG_PREFIX>-<serial_number>
ASSET_TAG_PREFIX=HAM

# Office locations (comma-separated)
# The frontend location filter dropdown is built from this list
LOCATIONS=HQ,Branch,Remote

# Provider selection
# MDM_PROVIDER: fleet | jamf | mosyle | kandji (only fleet implemented today)
# IDP_PROVIDER: okta | azure | google | auth0 (only okta implemented today)
# PRs welcome for additional provider support!
MDM_PROVIDER=fleet
IDP_PROVIDER=okta

# Admin groups (comma-separated group names from your identity provider)
ADMIN_GROUPS=IT-Admins,Asset-Managers

# ----- OIDC / Identity Provider (required for login) -----
# See docs/identity-providers.md for provider-specific setup
#
# Okta:      OIDC_ISSUER=https://your-domain.okta.com/oauth2/default
# Azure AD:  OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# Google:    OIDC_ISSUER=https://accounts.google.com
# Auth0:     OIDC_ISSUER=https://your-tenant.auth0.com/
OIDC_ISSUER=https://your-domain.okta.com/oauth2/default
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_REDIRECT_URI=http://localhost:3000/callback

# API token for user profile enrichment (department, location lookups)
# Okta: Okta API token
# Azure: not needed if using Microsoft Graph with client credentials
# Google: service account key path
IDP_API_TOKEN=your_idp_api_token

# ----- Fleet MDM (optional) -----
# See docs/fleet.md for setup instructions
FLEET_URL=https://your-fleet-instance.com
FLEET_API_TOKEN=your_fleet_api_token

# Fleet Sync Schedule
FLEET_SYNC_SCHEDULED=true
FLEET_SYNC_HOUR=21
FLEET_SYNC_MINUTE=0
FLEET_SYNC_TIMEZONE=US/Pacific

# ----- Apple Business Manager (optional) -----
# See docs/abm.md for setup instructions
ABM_CLIENT_ID=BUSINESSAPI.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ABM_KEY_ID=your_abm_key_id
ABM_PRIVATE_KEY_PATH=/app/keys/abm_private_key.pem

# ABM Sync Schedule
ABM_SYNC_SCHEDULED=true
ABM_SYNC_HOUR=20
ABM_SYNC_MINUTE=0

# AppleCare concurrency (reduce to 1-2 if hitting Apple rate limits)
APPLECARE_CONCURRENCY=2

# ----- Slack Alerts (optional) -----
# See https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# Legacy Okta-specific var names (kept for backwards compatibility)
# These map to OIDC_* vars above — prefer OIDC_* for new installs
# OKTA_ISSUER=
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_REDIRECT_URI=
# OKTA_API_TOKEN=
