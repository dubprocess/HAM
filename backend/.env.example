# Database Configuration
DATABASE_URL=postgresql://user:password@postgres:5432/asset_tracker

# Okta OIDC Configuration
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
OKTA_CLIENT_ID=your_client_id
OKTA_CLIENT_SECRET=your_client_secret
OKTA_REDIRECT_URI=http://localhost:3000/callback

# Okta API Configuration (for user profile lookups — location enrichment)
OKTA_API_TOKEN=your_okta_api_token

# Fleet MDM Configuration
FLEET_URL=https://your-fleet-instance.com
FLEET_API_TOKEN=your_fleet_api_token

# Apple Business Manager Configuration
ABM_CLIENT_ID=BUSINESSAPI.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ABM_KEY_ID=your_key_id
ABM_PRIVATE_KEY_PATH=/app/keys/abm_private_key.pem

# Application Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
SECRET_KEY=your-secret-key-here-change-in-production

# Corporate Email Domain(s) for auto-assignment (comma-separated)
# Only Chrome profile emails matching these domains will be used for auto-assignment
ALLOWED_EMAIL_DOMAINS=example.com

# Location Mapping (JSON: maps Okta city values to HAM location codes)
# Example: {"new york": "NYC", "san francisco": "SFO", "chicago": "ORD", "remote": "Remote"}
LOCATION_MAPPING={}

# Scheduled Fleet Sync
FLEET_SYNC_SCHEDULED=true
FLEET_SYNC_HOUR=21
FLEET_SYNC_MINUTE=0
FLEET_SYNC_TIMEZONE=US/Pacific

# Admin Groups (comma-separated Okta group names)
ADMIN_GROUPS=IT-Admins,Asset-Managers

# File Upload Configuration
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Email Configuration (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@company.com
