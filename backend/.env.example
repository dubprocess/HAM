# =============================================================
# HAM — Hardware Asset Manager — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# Database
DATABASE_URL=postgresql://assetuser:changeme123@postgres:5432/asset_tracker

# Application
SECRET_KEY=your-random-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000

# Asset tagging
# Asset tags are generated as <ASSET_TAG_PREFIX>-<serial_number>
ASSET_TAG_PREFIX=HAM

# Office locations (comma-separated)
LOCATIONS=HQ,Branch,Remote

# MDM / Identity provider (future: pluggable providers)
MDM_PROVIDER=fleet
IDP_PROVIDER=okta

# Admin groups (comma-separated Okta group names)
ADMIN_GROUPS=IT-Admins,Asset-Managers

# ----- Okta OIDC (required for login) -----
# See docs/okta.md for setup instructions
OKTA_ISSUER=https://your-domain.okta.com/oauth2/default
OKTA_CLIENT_ID=your_okta_client_id
OKTA_CLIENT_SECRET=your_okta_client_secret
OKTA_REDIRECT_URI=http://localhost:3000/callback
OKTA_API_TOKEN=your_okta_api_token

# ----- Fleet MDM (optional) -----
# See docs/fleet.md for setup instructions
FLEET_URL=https://your-fleet-instance.com
FLEET_API_TOKEN=your_fleet_api_token

# Fleet Sync Schedule
FLEET_SYNC_SCHEDULED=true
FLEET_SYNC_HOUR=21
FLEET_SYNC_MINUTE=0
FLEET_SYNC_TIMEZONE=US/Pacific

# ----- Apple Business Manager (optional) -----
# See docs/abm.md for setup instructions
ABM_CLIENT_ID=BUSINESSAPI.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ABM_KEY_ID=your_abm_key_id
ABM_PRIVATE_KEY_PATH=/app/keys/abm_private_key.pem

# ABM Sync Schedule
ABM_SYNC_SCHEDULED=true
ABM_SYNC_HOUR=20
ABM_SYNC_MINUTE=0

# AppleCare concurrency (reduce to 2 if hitting Apple rate limits)
APPLECARE_CONCURRENCY=2

# ----- Slack Alerts (optional) -----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760
